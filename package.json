    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@google/genai": "^1.45.0",
    "@lancedb/lancedb": "^0.26.2",
    "openai": "^4.80.0"
  },
  "devDependencies": {
    "@deepracticex/bdd": "latest",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0"
  }
}
