{
  "name": "swan-hackathon",
  "private": true,
  "version": "0.1.0",
  "description": "天鹅到家 AI Hackathon SDK — 招募生成、数据结构化、智能匹配",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
